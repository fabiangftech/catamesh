{
  "name": "catamesh-cli",
  "version": "0.0.1",
  "description": "CLI wrapper for Catalina Mesh commands",
  "private": false,
  "main": "dist/cli.js",
  "bin": {
    "cata": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js",
    "install:local:global": "npm install -g .",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/**/*.test.js",
    "uninstall:local:global": "npm uninstall -g catamesh-cli"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "typescript": "^5.8.3"
  },
  "author": {
    "name": "Fabián Guamán"
  }
}
